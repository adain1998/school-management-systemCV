{% extends 'base.html' %}

{% block title %}Paiements de la Classe{% endblock %}

{% block content %}
{% block styles %}
    <!-- Inclusion du CSS personnalisé -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/filter_paiement.css') }}">
{% endblock %}

<div class="container mt-5">
    <h1 class="mb-4">Paiements des Étudiants de la Classe</h1>

    {% if students %}
        <h2>Vue d'ensemble des paiements</h2>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID Étudiant</th>
                    <th>Nom</th>
                    <th>Montant Total Payé</th>
                </tr>
            </thead>
            <tbody>
                {% for student in students %}
                    <tr>
                        <td>{{ student.id }}</td>
                        <td>{{ student.nom }}</td>
                        <td>
                            {% set total = 0 %}
                            {% for payment in payments %}
                                {% if payment.student_id == student.id %}
                                    {% set total = total + payment.montant %}
                                {% endif %}
                            {% endfor %}
                            {{ total }} €
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <h2>Détails des paiements</h2>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID Paiement</th>
                    <th>ID Étudiant</th>
                    <th>Nom de l'Étudiant</th>
                    <th>Montant</th>
                    <th>Date</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                {% for payment in payments %}
                    <tr>
                        <td>{{ payment.id }}</td>
                        <td>{{ payment.student_id }}</td>
                        <td>
                            {% for student in students %}
                                {% if student.id == payment.student_id %}
                                    {{ student.nom }}
                                {% endif %}
                            {% endfor %}
                        </td>
                        <td>{{ payment.montant }} €</td>
                        <td>{{ payment.date.strftime('%d/%m/%Y') }}</td>
                        <td>{{ payment.statut }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>Aucun étudiant trouvé pour cette classe.</p>
    {% endif %}

    <a href="{{ url_for('paiem.index') }}" class="btn btn-secondary mt-4">Retour</a>
</div>
{% endblock %}

{% block scripts %}
    <!-- Inclusion du JS personnalisé -->
    <script src="{{ url_for('static', filename='js/filter_paiement.js') }}"></script>
{% endblock %}