{% extends 'base.html' %}

{% block title %}Liste des Étudiants{% endblock %}
 {% block styles %}
    <link rel="stylesheet" href="{{ url_for('static', filename='css/student_list.css') }}">
    {% endblock %}
   <link rel="icon" href="{{ url_for('static', filename='favicon-32x32.png') }}?v=1">
{% block content %}
<div class="container mt-5 student-container">
    <h1 class="text-center mb-4"><i class="fas fa-users"></i> Liste des Étudiants</h1>

    <!-- Flash Messages -->
    {% with messages = get_flashed_messages(with_categories=true) %}
        {% if messages %}
            {% for category, message in messages %}
                <div class="alert alert-{{ category }} mt-3">{{ message }}</div>
            {% endfor %}
        {% endif %}
    {% endwith %}

    <!-- Search Bar -->
    <form method="get" class="search-bar d-flex justify-content-center mb-4">
        <input type="text" name="q" class="form-control w-50 me-2"
               placeholder="🔍 Rechercher (nom, prénom, matricule)..."
               value="{{ request.args.get('q', '') }}">
        <button type="submit" class="btn btn-outline-primary">
            <i class="fas fa-search"></i> Rechercher
        </button>
    </form>

    <!-- Pagination — haut -->
    {% if pagination.has_prev or pagination.has_next %}
    <div class="d-flex justify-content-between align-items-center my-3">
        {% if pagination.has_prev %}
            <a class="btn btn-outline-primary" href="{{ url_for('stud.list_students', page=pagination.prev_num, q=request.args.get('q', ''), sort_by=sort_by) }}">
                ⬅ Page précédente
            </a>
        {% else %}
            <div></div>
        {% endif %}

        {% if pagination.has_next %}
            <a class="btn btn-outline-primary" href="{{ url_for('stud.list_students', page=pagination.next_num, q=request.args.get('q', ''), sort_by=sort_by) }}">
                Page suivante ➡
            </a>
        {% else %}
            <div></div>
        {% endif %}
    </div>
    {% endif %}

    <!-- Student Table -->
    <div class="table-responsive mb-4">
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th><a href="{{ url_for('stud.list_students', sort_by='nom', q=request.args.get('q', '')) }}" class="text-white">Nom</a></th>
                    <th><a href="{{ url_for('stud.list_students', sort_by='prenom', q=request.args.get('q', '')) }}" class="text-white">Prénom</a></th>
                    <th>Email</th>
                    <th>Classe</th>
                    <th>Date de Naissance</th>
                    <th><a href="{{ url_for('stud.list_students', sort_by='matricule', q=request.args.get('q', '')) }}" class="text-white">Matricule</a></th>
                    <th>Paiement</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for student in students %}
                    <tr>
                        <td>{{ loop.index + ((pagination.page - 1) * pagination.per_page) }}</td>
                        <td>{{ student.last_name }}</td>
                        <td>{{ student.first_name }}</td>
                        <td>{{ student.email }}</td>
                        <td>{{ student.class_name }}</td>
                        <td>{{student.date_naissance.strftime('%d/%m/%Y') if student.date_naissance else ''}}</td>
                        <td>{{ student.numero_matricule }}</td>
                        <td>{{ student.paiement }} $</td>
                        <td>
                            <a href="{{ url_for('stud.view_student', student_id=student.id) }}" class="btn btn-info btn-sm">Voir</a>
                            <a href="{{ url_for('stud.edit_student', student_id=student.id) }}" class="btn btn-warning btn-sm">Modifier</a>
                            <a href="{{ url_for('stud.delete_student', student_id=student.id) }}" class="btn btn-danger btn-sm" onclick="return confirm('Voulez-vous vraiment supprimer cet étudiant ?');">Supprimer</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-center">Aucun étudiant trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Compact List for Mobile -->
    <ul class="list-group d-md-none mb-4">
        {% for student in students %}
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <i class="fas fa-user-graduate me-2"></i>
                    <strong>{{ student.first_name }} {{ student.last_name }}</strong><br>
                    <small>Matricule : {{ student.numero_matricule }}</small><br>
                    <small>Créé le: {{ student.registration_date.strftime('%d/%m/%Y') if student.registration_date else '' }}</small>
                </div>
                <div>
                    <a href="{{ url_for('stud.view_student', student_id=student.id) }}" class="btn btn-sm btn-outline-info">Voir</a>
                </div>
            </li>
        {% endfor %}
    </ul>

    <!-- Pagination — numérotation -->
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            {% if pagination.has_prev %}
                <li class="page-item">
                    <a class="page-link" href="{{ url_for('stud.list_students', page=pagination.prev_num, q=request.args.get('q', ''), sort_by=sort_by) }}">Précédent</a>
                </li>
            {% endif %}

            {% for page_num in pagination.iter_pages() %}
                {% if page_num %}
                    <li class="page-item {% if page_num == pagination.page %}active{% endif %}">
                        <a class="page-link" href="{{ url_for('stud.list_students', page=page_num, q=request.args.get('q', ''), sort_by=sort_by) }}">{{ page_num }}</a>
                    </li>
                {% else %}
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                {% endif %}
            {% endfor %}

            {% if pagination.has_next %}
                <li class="page-item">
                    <a class="page-link" href="{{ url_for('stud.list_students', page=pagination.next_num, q=request.args.get('q', ''), sort_by=sort_by) }}">Suivant</a>
                </li>
            {% endif %}
        </ul>
    </nav>

    <!-- Pagination — bas -->
    {% if pagination.has_prev or pagination.has_next %}
    <div class="d-flex justify-content-between align-items-center my-3">
        {% if pagination.has_prev %}
            <a class="btn btn-outline-primary" href="{{ url_for('stud.list_students', page=pagination.prev_num, q=request.args.get('q', ''), sort_by=sort_by) }}">
                ⬅ Page précédente
            </a>
        {% else %}
            <div></div>
        {% endif %}

        {% if pagination.has_next %}
            <a class="btn btn-outline-primary" href="{{ url_for('stud.list_students', page=pagination.next_num, q=request.args.get('q', ''), sort_by=sort_by) }}">
                Page suivante ➡
            </a>
        {% else %}
            <div></div>
        {% endif %}
    </div>
    {% endif %}
    <div class="mb-3">
  <button id="download-pdf" class="btn btn-danger">Télécharger PDF</button>
  <button id="download-csv" class="btn btn-primary">Télécharger CSV</button>
</div>
    <!-- Add Button -->
    <div class="text-center mt-4">
        <a href="{{ url_for('stud.add_student') }}" class="btn btn-success">
            <i class="fas fa-user-plus"></i> Ajouter un Étudiant
        </a>
    </div>
</div>
{% block scripts %}
<script src="{{ url_for('static', filename='js/student_list.js') }}"></script>
{% endblock %}
