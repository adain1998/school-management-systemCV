{% extends "base.html" %}

{% block title %}Ajouter un Frais{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="{{ url_for('static', filename='css/add_fee.css') }}">
  <!-- Toastr CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
{% endblock %}

{% block content %}
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card p-4 shadow-sm">
        <h3 class="mb-4 text-primary fw-bold text-center">
          <i data-lucide="file-plus" class="me-2"></i>Ajouter un Frais
        </h3>

        <form method="POST" action="{{ url_for('paie.add_fee') }}">
          <div class="mb-3">
            <label for="student_nom" class="form-label">
              <i data-lucide="user"></i> Nom de l'élève
            </label>
            <input type="text" name="student_nom" id="student_nom" class="form-control" required>
          </div>

          <div class="mb-3">
            <label for="montant" class="form-label">
              <i data-lucide="dollar-sign"></i> Montant (FC)
            </label>
            <input type="number" name="montant" id="montant" class="form-control" required min="0">
          </div>

          <div class="mb-3">
            <label for="status" class="form-label">
              <i data-lucide="check-circle"></i> Statut
            </label>
            <select name="status" id="status" class="form-select" required>
              <option value="payé">Payé</option>
              <option value="non payé">Non payé</option>
            </select>
          </div>

          <div class="mb-3">
            <label for="description" class="form-label">
              <i data-lucide="align-left"></i> Description (facultatif)
            </label>
            <textarea name="description" id="description" class="form-control" rows="3"></textarea>
          </div>

          <div class="d-flex justify-content-between">
            <a href="{{ url_for('paie.view_fees') }}" class="btn btn-secondary">
              <i data-lucide="arrow-left"></i> Retour à la liste
            </a>
            <button type="submit" class="btn btn-primary">
              <i data-lucide="save"></i> Enregistrer
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
  <!-- fees.js -->
  <script src="{{ url_for('static', filename='js/add_fee.js') }}"></script>

  <!-- Toastr JS -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    lucide.createIcons();
  </script>

  <script>
    // Toastr configuration
    toastr. Options = {
      "closeButton": true,
      "progressBar": true,
      "positionClass": "toast-top-right",
      "timeOut": "5000"
    };

    // Afficher les messages flash avec Toastr
    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        {% for category, message in messages %}
          {% if category == 'success' %}
            toastr.success("{{ message }}");
          {% elif category == 'error' %}
            toastr.error("{{ message }}");
          {% elif category == 'warning' %}
            toastr.warning("{{ message }}");
          {% else %}
            toastr.info("{{ message }}");
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endwith %}
  </script>
{% endblock %}
